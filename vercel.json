{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "all"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/SongPractice/:source_id",
      "destination": "/api/song?source_id=:source_id"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
